{
  "name": "vwd",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vercel dev",
    "install:all": "npm install && npm --prefix ./widget install && npm --prefix ./admin install",
    "build": "npm --prefix ./widget install && npm --prefix ./widget run build && npm --prefix ./admin install && npm --prefix ./admin run build",
    "build:widget": "npm --prefix ./widget install && npm --prefix ./widget run build",
    "build:admin": "npm --prefix ./admin install && npm --prefix ./admin run build",
    "deploy": "npm run build && vercel --prod",
    "db:init": "node scripts/init-db.cjs"
  },
  "dependencies": {
    "@vercel/kv": "^3.0.0",
    "@vercel/postgres": "^0.10.0",
    "aws4fetch": "^1.0.20",
    "hono": "^4.6.0",
    "marked": "^14.1.3",
    "node-emoji": "^2.2.0",
    "nodemailer": "^6.9.16",
    "ua-parser-js": "^1.0.39",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/ua-parser-js": "^0.7.39",
    "typescript": "^5.6.0",
    "vercel": "^37.0.0"
  }
}
