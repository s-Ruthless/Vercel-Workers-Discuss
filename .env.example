# ==================== 管理员账号 ====================
# 管理后台登录用户名和密码
ADMIN_NAME=Admin
ADMIN_PASSWORD=your_password_here

# ==================== Vercel Postgres ====================
# 在 Vercel 控制台创建 Postgres 后自动注入以下变量:
# POSTGRES_URL=postgres://...
# POSTGRES_URL_NON_POOLING=postgres://...

# ==================== Vercel KV ====================
# 在 Vercel 控制台创建 KV 后自动注入以下变量:
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...
